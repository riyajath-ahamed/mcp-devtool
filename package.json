{
  "name": "mcp-devtools",
  "private": true,
  "description": "Browser DevTools-style inspector for MCP tool calls and agent sessions",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "release": "pnpm build && changeset publish",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.2.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}

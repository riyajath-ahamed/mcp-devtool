{
  "name": "@configkits/mcp-devtools-bridge",
  "version": "0.1.0",
  "description": "WebSocket bridge and HTTP server for MCP DevTools",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["mcp", "devtools", "websocket", "bridge"],
  "license": "MIT",
  "dependencies": {
    "@configkits/mcp-devtools-core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
